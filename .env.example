# Gated Nostr relay where kind 1163 membership events live.
# Used by the NIP-63 access path. The service queries this relay over
# WebSocket on each /check-access call.
GATED_RELAY_URL=ws://strfry-gated:7777

# Supabase connection (or any Postgres-backed API).
# Optional: leave unset if you only want the NIP-63 path.
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=your-service-role-key

# Server
PORT=3003
HOST=0.0.0.0
